# ── Local Ollama (optional — for zero-cost local inference) ───────────────────
# Leave blank to use Groq only
# Setup: brew install ollama && ollama pull llama3.2:3b-instruct-q8_0
OLLAMA_BASE_URL=http://localhost:11434

# ── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
