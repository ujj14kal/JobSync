APP_VERSION=dev

# ── Supabase ──────────────────────────────────────────────────────────────────
# Production project (ap-south-1)
SUPABASE_URL=https://dzdziagugdcbkictslrt.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImR6ZHppYWd1Z2RjYmtpY3RzbHJ0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk4NTcwMjYsImV4cCI6MjA5NTQzMzAyNn0.1nf7Um3PDSZMzHaBmf2bIzgEqzwpClEp1i_leRnLBYE
# Get from: Supabase Dashboard → Settings → API → service_role key
